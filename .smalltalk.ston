SmalltalkCISpec {
  #loading : [
    SCIMetacelloLoadSpec {
      #baseline : 'FamixExecutionFlow',
      #onConflict : #useIncoming,
      #load: [ 'all' ],
      #directory : 'src',
      #platforms : [ #pharo ]
    }
  ],
  #testing : {
    #coverage : {
      #packages : [
        'Famix-ExecutionFlow-Entities-Extensions',
        'Famix-ExecutionFlow-Value-Entities-Extensions'
      ],
      #format : #lcov
    }
  }
}
